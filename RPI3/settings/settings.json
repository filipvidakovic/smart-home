{
    "device": {
        "pi_id": "PI3",
        "device_name": "RaspberryPi_Bedrooms",
        "location": "Bedrooms",
        "description": "Bedroom and Master Bedroom monitoring device with LCD display"
    },
    "mqtt": {
        "broker": "localhost",
        "port": 1883,
        "client_id": "PI3_client",
        "topics": {
            "temperature": "sensors/temperature",
            "motion": "sensors/motion"
        },
    "batch_size": 5,
    "batch_interval": 10
    },


    "DHT1": {
        "simulated": true,
        "pin": 1,
        "read_interval": 2,
        "location": "Bedroom"
    },
    "DHT2": {
        "simulated": true,
        "pin": 2,
        "read_interval": 2,
        "location": "Master Bedroom"
    },
    "IR": {
        "simulated": true,
        "pin": 3
    },
    "BRGB": {
        "simulated": true,
        "red_pin": 17,
        "green_pin": 27,
        "blue_pin": 22
    },
    "LCD": {
        "simulated": true,
        "i2c_address": 39,
        "i2c_bus": 1,
        "update_interval": 3.0,
        "display_mode": "both",
        "location": "Living Room"
    },
    "DPIR3": {
        "simulated": true,
        "pin": 6
    }


}